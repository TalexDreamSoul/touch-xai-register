# Copy to a private path (e.g. /tmp/touch-xai-refill/refill.env) and chmod 600.
# Used by scripts/refill-watchdog.sh (ENV_FILE) and continuous-refill.sh.

PANEL_URL=http://127.0.0.1:8787
PANEL_TOKEN=replace-with-panel-token

# Batch size per registration run (probe-success count)
BATCH_TARGET=20

# Optional: push each finished CPA zip into a candidate-upload endpoint.
# Leave CANDIDATE_TOKEN empty to skip HTTP upload (zip still saved under WORK_DIR/runs/).
# CANDIDATE_UPLOAD_URL=https://example.com/candidate-upload/api/v1/upload
# CANDIDATE_TOKEN=

BATCH_COOLDOWN_SEC=45
POLL_SEC=15
# 0 = run forever
MAX_BATCHES=0
WORK_DIR=/tmp/touch-xai-refill
