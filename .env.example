# Copy to .env before: docker compose up -d --build  或  make up
#
# 本机默认:
#   make up          → 复用已运行全家桶，或 clearance + 宿主 panel
#   make docker-up   → 完整 Docker 栈
#   make status      → 健康检查

# Panel auth (required if exposed beyond localhost)
PANEL_TOKEN=local-dev-token

# Host port for the web panel
PANEL_PORT=8787

# Optional host debug ports (loopback only in compose)
# WARP_SOCKS_PORT=40000
# PRIVOXY_PORT=40080
# FLARESOLVERR_PORT=8191

TZ=Asia/Shanghai
EMAIL_MODE=tempmail

# Optional: auto-upload CPA JSON to Management API
# 密钥更建议写进 volume 内 /data/config.env，避免空 env 覆盖
# CPA_UPLOAD_ENABLED=0
# CPA_MANAGEMENT_BASE=http://host.docker.internal:8317/v0/management
# CPA_MANAGEMENT_KEY=

# Optional WARP+ license
# WARP_LICENSE_KEY=
