# Copy to .env before: docker compose up -d --build

# Required for public exposure — long random string
PANEL_TOKEN=change-me-to-a-long-random-secret

# Host port for the web panel
PANEL_PORT=8787

# Optional host debug ports (loopback only in compose)
# WARP_SOCKS_PORT=40000
# PRIVOXY_PORT=40080
# FLARESOLVERR_PORT=8191

TZ=Asia/Shanghai
EMAIL_MODE=tempmail

# Optional: auto-upload CPA JSON to Management API
# CPA_UPLOAD_ENABLED=0
# CPA_MANAGEMENT_BASE=http://host.docker.internal:8317/v0/management
# CPA_MANAGEMENT_KEY=

# Optional WARP+ license
# WARP_LICENSE_KEY=
