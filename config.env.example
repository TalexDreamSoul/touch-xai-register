# 复制到 ~/.grok/config.env 或首次 grok start 交互生成

EMAIL_MODE=tempmail
# EMAIL_MODE=custom
# EMAIL_DOMAIN=example.com
# EMAIL_API=http://127.0.0.1:8080
#
# FreeMail (Cloudflare Worker from apps/cloudflare-mail / opctoai-toolkit)
# EMAIL_MODE=freemail
# FREEMAIL_BASE=https://your-mail-worker.example.workers.dev
# FREEMAIL_API_KEY=your-worker-jwt-token
# EMAIL_DOMAIN=mail.example.com
#
# Or keep EMAIL_MODE=custom and point EMAIL_API at the local mail-bridge:
# EMAIL_MODE=custom
# EMAIL_DOMAIN=mail.example.com
# EMAIL_API=http://127.0.0.1:18431

CLEARANCE_ENABLED=1
REGISTER_PROXY=http://127.0.0.1:40080
FLARESOLVERR_URL=http://127.0.0.1:8191
CLEARANCE_PROXY=http://privoxy:8118
CLEARANCE_URLS=https://accounts.x.ai,https://x.ai,https://status.x.ai,https://console.x.ai,https://auth.x.ai

# Turnstile：默认本机浏览器 mint（无需外部 farm）
TURNSTILE_PROVIDER=browser
# 可选：外接 YesCaptcha 形 farm
# TURNSTILE_PROVIDER=lite
# LITE_SOLVER_URL=http://127.0.0.1:5072
# CHROME_PATH=                         # 可选；默认自动找 Chrome / ~/.cloakbrowser

PROTOCOL_HTTP=1
HTTP_POOL_SIZE=8
TEMPMAIL_LOL_RETRIES=30
TEMPMAIL_LOL_MIN_INTERVAL_MS=1500

HTTPS_PROXY=http://127.0.0.1:40080
HTTP_PROXY=http://127.0.0.1:40080
NO_PROXY=127.0.0.1,localhost

PROBE_ENABLED=1
PHYSICAL_CAP=0

# CPA Management 自动上传（宿主机 grok 用 127.0.0.1，不要写 docker 服务名）
# Docker 内网名如 http://cli-proxy-api:8317 仅容器间可解析；宿主机会 DNS 失败。
# 路径需含 /v0/management（上传会再拼 /auth-files）
# CPA_UPLOAD_ENABLED=0
# CPA_MANAGEMENT_BASE=http://127.0.0.1:8317/v0/management
# CPA_MANAGEMENT_KEY=
# CPA_UPLOAD_TIMEOUT_SEC=30
# CPA_UPLOAD_RETRIES=2
# CPA_UPLOAD_NAME_TEMPLATE={email}.json
# CPA_UPLOAD_VERIFY=1
# CPA_UPLOAD_MODE=multipart

# ===== 面板：上传 / 导出默认值 =====
# UPLOAD_CONCURRENCY=3
# UPLOAD_BATCH_SIZE=20
# EXPORT_BATCH_SIZE=500
# EXPORT_CONCURRENCY=15

# ===== 面板：号池自动巡检（随 grok panel 进程运行）=====
# PATROL_ENABLED=0          # 1=面板启动后按间隔巡检
# PATROL_INTERVAL_MIN=30
# PATROL_DEEP_PROBE=0       # 1=下载凭证真实探活（慢但准，可识别限流/耗尽）
# PATROL_CONCURRENCY=10
# QUOTA_PER_ACCOUNT=60      # 单健康号估算日额度（请求数）

# ===== 面板：自动补号（巡检后健康号不足时自动启动注册）=====
# REFILL_ENABLED=0
# REFILL_MIN_HEALTHY=5      # 健康号低于此值触发
# REFILL_BATCH=10           # 每次补号 target
# REFILL_COOLDOWN_MIN=60    # 两次补号最小间隔
# REFILL_DAILY_CAP=50       # 单日补号上限

# ===== 清理限额耗尽号（正式池废号，不删纯 429 限流）=====
# CLEANUP_QUOTA_ENABLED=0   # 1=允许定时清理路径
# CLEANUP_ON_PATROL=1       # 巡检成功后自动跑
# CLEANUP_BACKUP=1          # 删除前下载到 GROK_HOME/pool-backups/
# CLEANUP_DRY_RUN=0         # 1=只报告不删除

# ===== 主从调度（panel 联邦）=====
# CLUSTER_ROLE=standalone   # standalone | master | slave
# CLUSTER_NODE_NAME=node-a
# CLUSTER_PUBLIC_TOKEN=     # 可选，主从一致；公网联邦鉴权
# CLUSTER_MASTER_URL=       # 从节点单主（兼容）
# CLUSTER_MASTER_URLS=      # 从节点多主，逗号/换行分隔
# CLUSTER_STATUS_PASSWORD=  # 公网状态页密码（与联邦密钥独立；空=公开）
# CLUSTER_HEARTBEAT_SEC=15
# CLUSTER_POOL_TARGET=50    # 主：号池维持健康数
# CLUSTER_ASSIGN_MIN=1      # 主：单次分配下限 1-10
# CLUSTER_ASSIGN_MAX=10     # 主：单次分配上限 1-10
# CLUSTER_AUTO_REGISTER=1   # 从：收到分配后自动 grok start
# CLUSTER_AUTO_UPLOAD=1     # 从：批次结束后尝试上传
